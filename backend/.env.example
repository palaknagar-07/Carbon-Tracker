NODE_ENV=development
PORT=3001

# Required in production for CORS.
ALLOWED_ORIGINS=http://localhost:3000

# Firebase Admin credentials: choose ONE approach.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=

# Required for route verification/directions.
OPENROUTESERVICE_API_KEY=

# Recommended in production.
ROUTE_TOKEN_SECRET=
TRUST_PROXY=0

# Optional tuning values.
MAX_COMMUTE_DISTANCE_KM=5000
MIN_TRIP_INTERVAL_SECONDS=60
MAP_ROUTE_TOKEN_TTL_SECONDS=900
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_COMMUTE_MAX=120
RATE_LIMIT_READ_MAX=200

# Local-only helper, never enable in production.
USE_MOCK_FIRESTORE=false
