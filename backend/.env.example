NODE_ENV=production
PORT=3001

# Comma-separated browser origins allowed to call the API (CORS)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Set to 1 when running behind a reverse proxy (nginx, Render, Railway, etc.)
TRUST_PROXY=1

# Firebase Admin — preferred for hosted environments (entire JSON on one line)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Or use split variables (common on Heroku-style platforms)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n......\n-----END PRIVATE KEY-----\n"

# Optional: Realtime Database URL only if you use RTDB
# FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Optional tuning
# BCRYPT_ROUNDS=12
# MAX_COMMUTE_DISTANCE_KM=5000
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_COMMUTE_MAX=120
# RATE_LIMIT_READ_MAX=200

# Local-only: in-memory mock (never use in production)
# USE_MOCK_FIRESTORE=false
