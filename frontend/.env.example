# Public API base URL (no trailing slash). Production example:
# REACT_APP_API_URL=https://your-api.onrender.com
#
# OpenRouteService API key (optional — without it, straight-line distance is used)
# REACT_APP_OPENROUTESERVICE_API_KEY=
#
# Optional: email for Nominatim (India From/To search) per OSM usage policy
# REACT_APP_NOMINATIM_EMAIL=contact@yourdomain.com

# Local development
# REACT_APP_API_URL=http://localhost:3001

# Optional: Firebase client SDK if you add client-side Firebase later
# REACT_APP_FIREBASE_API_KEY=
# REACT_APP_FIREBASE_AUTH_DOMAIN=
# REACT_APP_FIREBASE_PROJECT_ID=
